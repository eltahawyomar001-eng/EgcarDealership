{
  "name": "CarOS Egypt",
  "short_name": "CarOS",
  "description": "Smart Dealership Management System for Egypt",
  "start_url": "/dashboard",
  "scope": "/",
  "id": "/dashboard",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#030712",
  "theme_color": "#0ea5e9",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
